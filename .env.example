# .env.example — plantilla pública para el .env local.
#
# Este archivo SÍ se versiona en git como guía para el equipo.
# El `.env` real (con tus valores) NUNCA se versiona.
#
# Onboarding al clonar el repo:
#   1. cp .env.example .env
#   2. Cambia POSTGRES_PASSWORD por una contraseña fuerte propia.
#   3. Genera DJANGO_SECRET_KEY con:
#        docker-compose run --rm web python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#   4. Verifica que .env NO aparezca en `git status` antes del primer commit.

# === Postgres (base de datos) ===
# Los valores convencionales son OK como ejemplo; cámbialos si quieres.
# Lo que SÍ debe cambiarse: POSTGRES_PASSWORD.
POSTGRES_DB=fairbet_db
POSTGRES_USER=fairbet_admin
POSTGRES_PASSWORD=changeme-use-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Cambia POSTGRES_PORT_HOST a 5433 si ya tienes Postgres local en 5432.
POSTGRES_PORT_HOST=5432

# === Django ===
# DJANGO_SECRET_KEY: NUNCA pegues una clave real aquí ni en commits.
# Genera la tuya con el comando del paso 3 del onboarding.
DJANGO_SECRET_KEY=replace-with-50-char-random-key-generated-locally
# Solo True en desarrollo. En producción: False.
DJANGO_DEBUG=True
# Lista separada por comas. En producción: hosts específicos.
DJANGO_ALLOWED_HOSTS=*

# === Redis (Django Channels) ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PORT_HOST=6379